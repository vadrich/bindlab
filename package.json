{
  "name": "bindlab",
  "private": true,
  "version": "1.0.0",
  "description": "BindLab — CS2 bind & settings generator with a visual buy menu",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run og && tsc -b && vite build",
    "preview": "vite preview",
    "og": "node scripts/generate-og-image.mjs",
    "icons": "node scripts/generate-weapon-icons.mjs",
    "deploy": "node scripts/deploy-firebase.mjs",
    "deploy:hosting": "firebase deploy --only hosting --project bindlab --non-interactive"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "firebase-tools": "^15.24.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.3",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
