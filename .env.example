# Copy to .env.local (dev) and/or .env.production (build)

# Public site URL for OG / sitemap (no trailing slash)
VITE_SITE_URL=https://bindlab.ru

# Yandex Metrika (visitors / pageviews)
# 1) https://metrika.yandex.ru → Добавить счётчик → укажи домен bindlab.ru
# 2) Скопируй номер счётчика (только цифры) сюда и в env хостинга
# 3) После деплоя смотри отчёты: https://metrika.yandex.ru
VITE_YANDEX_METRIKA_ID=110829565

# Firebase Auth + Hosting (project: bindlab)
# Hosting: npm run deploy
# Custom domain: Firebase Console → Hosting → Add custom domain → bindlab.ru
# Auth: Authentication → Settings → Authorized domains → add bindlab.ru
# 1) https://console.firebase.google.com → project bindlab
# 2) Build → Authentication → Get started
# 3) Enable Email/Password and Google
# 4) Project settings → Your apps → Web app → copy config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=bindlab
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
